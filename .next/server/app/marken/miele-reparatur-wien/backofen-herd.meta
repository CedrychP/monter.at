{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/marken/layout,_N_T_/marken/[slug]/layout,_N_T_/marken/[slug]/[geraet]/layout,_N_T_/marken/[slug]/[geraet]/page,_N_T_/marken/miele-reparatur-wien/backofen-herd"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/marken/$d$slug/$d$geraet/__PAGE__",
    "/marken/$d$slug/$d$geraet",
    "/marken/$d$slug",
    "/marken",
    "/_index",
    "/_head"
  ]
}