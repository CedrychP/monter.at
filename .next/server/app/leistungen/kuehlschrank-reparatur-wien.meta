{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/leistungen/layout,_N_T_/leistungen/[slug]/layout,_N_T_/leistungen/[slug]/page,_N_T_/leistungen/kuehlschrank-reparatur-wien"
  },
