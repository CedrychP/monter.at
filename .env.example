# Kopiere diese Datei zu .env.local und trage die echten Werte ein.

# === Microsoft Graph (OAuth2 / App-Registrierung) ===
# Aus der Entra App-Registrierung: Verzeichnis-(Mandanten-)ID, Anwendungs-(Client-)ID
# und ein Client-Secret. Die App braucht die Application-Permission "Mail.Send"
# (mit Administratoreinwilligung).
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=dein-client-secret

# Absender-Postfach (muss ein echtes Postfach im Tenant sein).
MAIL_FROM=postfach@monter.at

# === Empfänger pro Formular ===
CONTACT_TO_SERVICE=service@monter.at        # Reparaturformular (Startseite + /reparatur-buchen)
CONTACT_TO_PARTS=ersatzteile@monter.at      # Ersatzteilformular (/ersatzteile)
CONTACT_TO_INFO=info@monter.at              # Anliegenformular (/kontakt)
CONTACT_TO_SALES=sales@monter.at            # Firmenkundenformular (/firmenkunden)
CONTACT_TO_KARRIERE=karriere@monter.at      # Bewerbungsformular (/karriere)
CONTACT_TO_NEWSLETTER=noreply@monter.at     # Newsletter-Anmeldungen

# Fallback, falls eine der obigen Variablen fehlt
CONTACT_TO=info@monter.at
